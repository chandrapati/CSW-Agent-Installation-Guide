# Managed by Ansible — do not edit by hand.
#
# CAVEAT: /etc/tetration/sensor.conf is a community
# config-management convention, NOT a path the Cisco-shipped CSW
# agent reads by default. The agent reads its sensor config from
# inside its install root (typically /usr/local/tet/). If you use
# this template, you must either:
#   1. Generate an installer that already has the activation key
#      baked in (Cisco-supported), and treat this file as an
#      Ansible-managed audit copy; or
#   2. Add a wrapper task that translates this file into the
#      format your release of the agent actually consumes.
ACTIVATION_KEY={{ csw_activation_key }}
SCOPE={{ csw_scope }}
{% if csw_proxy_host is defined %}
HTTPS_PROXY_HOST={{ csw_proxy_host }}
HTTPS_PROXY_PORT={{ csw_proxy_port | default(8080) }}
{% endif %}
